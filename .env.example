NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider: DeepSeek (OpenAI-compatible). Server-only. ---
# Create a key at https://platform.deepseek.com (add credits first, then API keys).
DEEPSEEK_API_KEY=
# deepseek-chat (V3, default) for structured JSON tasks; deepseek-reasoner (R1) for harder reasoning.
DEEPSEEK_MODEL_ID=deepseek-chat
# Override only when routing through a proxy or self-hosted gateway.
DEEPSEEK_BASE_URL=https://api.deepseek.com
